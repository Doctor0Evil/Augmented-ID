-- ============================================================================
-- FILE: vc.peacekeeper.v1.aln
-- NAMESPACE: AugID.VC.Peacekeeper
-- VERSION: 1.0.0
-- DESCRIPTION: Peacekeeper credential VC (de-escalation, reporting, civic support)
-- ANCHOR: ROWRPM shard linked to AugmentedCitizenID
-- ============================================================================

namespace AugID.VC.Peacekeeper v1

-- Import core ALN primitives
import ALN.Core v1
import ALN.Crypto v1
import AugID.VC.Core v1

-- ============================================================================
-- RECORD: PeacekeeperVC
-- PURPOSE: Non-speculative, neurorights-safe civic contribution credential
-- INVARIANTS: Events immutable, disputes as additional VCs never deletion
-- ============================================================================

record PeacekeeperVC extends VCCoreEnvelope
  -- Override schemaref
  schemaref = "au.vc.peacekeeper.v1"
  
  -- Payload fields (civic action documentation)
  event_type            enum      -- Deescalation, AccurateIncidentReport, Mediation,
                                  -- HazardDocumentation, CommunitySupport
  verified_by           list<string>  -- DIDs of officers, mediators, civic systems
  evidence_bundle_ref   string    -- Pointer to evidence shard (video/audio hashes under Rprivacy)
  peacekeeping_index_delta float   -- Non-transferable score increment
  
  -- Protection flags
  retaliation_protection bool     -- Extra witness-protection constraints (pseudonymized view)
  anonymity_level       enum      -- Full, Partial, None (based on safety requirements)
  
  -- Rights envelope
  rights_envelope_ref   string    -- Neurorights constraints for this VC

-- ============================================================================
-- RECORD: PeacekeeperVCDispute
-- PURPOSE: Dispute or correction record (append-only, linked by vcid)
-- INVARIANTS: Never deletes original event, creates parallel dispute record
-- ============================================================================

record PeacekeeperVCDispute
  entryid               string
  original_vcid         string    -- Reference to original PeacekeeperVC
  dispute_reason        enum      -- FactualError, ContextMissing, MaliciousReport
  dispute_evidence_ref  string    -- Hash reference to counter-evidence
  disputed_at           datetime
  author_did            string
  signature             string
  antirollback          bool      -- MUST be true
  resolution_status     enum      -- Pending, Resolved, Dismissed

-- ============================================================================
-- GUARD: PeacekeeperVCGuard
-- PURPOSE: Enforce peacekeeper VC invariants and witness protection
-- ============================================================================

guard PeacekeeperVCGuard extends VCCoreEnvelopeGuard
  -- Compile-time invariants
  invariant event_type_valid:
    self.event_type in [
      "Deescalation", "AccurateIncidentReport", "Mediation",
      "HazardDocumentation", "CommunitySupport"
    ]
  
  invariant peacekeeping_index_delta_non_negative:
    self.peacekeeping_index_delta >= 0.0
  
  invariant verified_by_minimum:
    -- At least one verifier required for credibility
    len(self.verified_by) >= 1
  
  invariant evidence_bundle_privacy:
    -- Evidence must be hash-only, no raw data references
    self.evidence_bundle_ref =~ "^sha256:[a-f0-9]{64}$"
  
  invariant anonymity_level_valid:
    self.anonymity_level in ["Full", "Partial", "None"]
  
  -- Retaliation protection invariants
  invariant retaliation_protection_requires_anonymity:
    if self.retaliation_protection == true:
      self.anonymity_level in ["Full", "Partial"]
  
  -- Neurorights invariants
  invariant noscorefrominnerstate_asserted:
    rights_envelope = lookup_rights_envelope(self.rights_envelope_ref)
    "noscorefrominnerstate" in rights_envelope.flags
  
  invariant no_exclusion_basic_services:
    rights_envelope = lookup_rights_envelope(self.rights_envelope_ref)
    "no_exclusion_basic_services" in rights_envelope.flags
  
  -- Runtime invariants
  invariant public_dashboard_safe:
    -- Public dashboards aggregate only corridor-safe metrics
    -- Never expose raw evidence or inner-state data
    self.evidence_bundle_ref is_hash_only()

-- ============================================================================
-- FUNCTION: Peacekeeper VC Minimal Token Projection
-- PURPOSE: Generate BfcToken.v1 view from PeacekeeperVC (coarse band only)
-- ============================================================================

function project_peacekeeper_token(vc: PeacekeeperVC) -> map<string,any>
  return {
    "vc_type": "peacekeeper",
    "event_type_band": band_event_type(vc.event_type),
    "peacekeeping_index_band": band_peacekeeping_score(vc.peacekeeping_index_delta),
    "verified_count": len(vc.verified_by),
    "retaliation_protection": vc.retaliation_protection,
    "anonymity_level": vc.anonymity_level,
    "rights_header": lookup_rights_envelope(vc.rights_envelope_ref).flags
  }

-- ============================================================================
-- FUNCTION: Band Peacekeeping Score (coarse-grained for privacy)
-- ============================================================================

function band_peacekeeping_score(score: float) -> string
  if score >= 100.0:
    return "Platinum"
  elif score >= 50.0:
    return "Gold"
  elif score >= 25.0:
    return "Silver"
  elif score >= 10.0:
    return "Bronze"
  else:
    return "Participant"

-- ============================================================================
-- FUNCTION: Band Event Type (generalized for privacy)
-- ============================================================================

function band_event_type(event_type: string) -> string
  if event_type in ["Deescalation", "Mediation"]:
    return "ConflictResolution"
  elif event_type in ["AccurateIncidentReport", "HazardDocumentation"]:
    return "Reporting"
  elif event_type == "CommunitySupport":
    return "CommunitySupport"
  else:
    return "Unknown"

-- END OF FILE
